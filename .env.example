# ============================================================
# Portal Meditatii Mate – Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# ------------------------------------------------------------
# Supabase (get these from: Project Settings → API)
# ------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ------------------------------------------------------------
# Admin credentials
# Set a strong password – this protects your entire admin panel.
# The email can be anything (it's just the Supabase Auth identity).
# You register this once via the Supabase dashboard or CLI,
# then never change it unless you want to update the password.
# ------------------------------------------------------------
# ADMIN_EMAIL=admin@yourdomain.com     ← set in Supabase Auth, not here
# ADMIN_PASSWORD=...                  ← set in Supabase Auth, not here

# ------------------------------------------------------------
# Optional: used only if you add Stripe later
# ------------------------------------------------------------
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
